<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key><string>Argus</string>
    <key>CFBundleDisplayName</key><string>Argus</string>
    <key>CFBundleIdentifier</key><string>dev.universaltmux.mac</string>
    <key>CFBundleExecutable</key><string>Argus</string>
    <key>CFBundleIconFile</key><string>Argus</string>
    <key>CFBundlePackageType</key><string>APPL</string>
    <key>CFBundleShortVersionString</key><string>0.1</string>
    <key>CFBundleVersion</key><string>1</string>
    <key>LSMinimumSystemVersion</key><string>13.0</string>
    <key>NSHighResolutionCapable</key><true/>
    <key>NSPrincipalClass</key><string>NSApplication</string>
    <!-- Brokers reached over the tailnet may serve plain HTTP (a broker bound to a
         host's own tailnet IP, e.g. Windows via the Tailscale app, has no TLS).
         ATS blocks cleartext to remote hosts by default, which silently hid those
         machines from discovery. Allow cleartext: the "plaintext" still travels
         inside Tailscale's encrypted WireGuard tunnel. -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key><true/>
    </dict>
</dict>
</plist>
