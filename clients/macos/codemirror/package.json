{
  "name": "ut-codemirror",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "description": "Bundled CodeMirror 6 editor for the universal_tmux Files browser (loaded in a WKWebView).",
  "scripts": {
    "build": "esbuild src/editor.js --bundle --format=iife --outfile=../Resources/codemirror/editor.js --minify --legal-comments=none"
  },
  "dependencies": {
    "@codemirror/commands": "^6",
    "@codemirror/lang-cpp": "^6",
    "@codemirror/lang-css": "^6",
    "@codemirror/lang-go": "^6",
    "@codemirror/lang-html": "^6",
    "@codemirror/lang-java": "^6",
    "@codemirror/lang-javascript": "^6",
    "@codemirror/lang-json": "^6",
    "@codemirror/lang-markdown": "^6",
    "@codemirror/lang-php": "^6",
    "@codemirror/lang-python": "^6",
    "@codemirror/lang-rust": "^6",
    "@codemirror/lang-sql": "^6",
    "@codemirror/lang-xml": "^6",
    "@codemirror/lang-yaml": "^6",
    "@codemirror/language": "^6",
    "@codemirror/legacy-modes": "^6",
    "@codemirror/search": "^6",
    "@codemirror/state": "^6",
    "@codemirror/theme-one-dark": "^6",
    "@codemirror/view": "^6"
  },
  "devDependencies": {
    "esbuild": "^0.24"
  }
}
